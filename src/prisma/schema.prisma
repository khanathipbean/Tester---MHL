generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String?
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  suites      TestSuite[]
  testCases   TestCase[]
  testRuns    TestRun[]
  defects     Defect[]
  tags        Tag[]

  @@index([status])
}

model TestSuite {
  id          String      @id @default(cuid())
  projectId   String
  parentId    String?
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      TestSuite?  @relation("SuiteHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    TestSuite[] @relation("SuiteHierarchy")
  testCases   TestCase[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([parentId])
}

model TestCase {
  id                    String          @id @default(cuid())
  projectId             String
  suiteId               String?
  key                   String
  title                 String
  description           String?
  preconditions         String?
  condition             String?
  testSteps             String?
  expectedResult        String?
  priority              String          @default("MEDIUM")
  type                  String          @default("FUNCTIONAL")
  status                String          @default("DRAFT")
  automationStatus      String          @default("MANUAL")
  notes                 String?
  clarificationRequired Boolean         @default(false)
  inProgress            Boolean         @default(false)
  tested                Boolean         @default(false)
  createdByName         String?
  updatedByName         String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  project               Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suite                 TestSuite?      @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  steps                 TestStep[]
  executions            TestExecution[]
  defects               Defect[]
  tags                  TestCaseTag[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([suiteId])
}

model TestStep {
  id             String   @id @default(cuid())
  testCaseId     String
  position       Int
  action         String
  expectedResult String
  testData       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  testCase       TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, position])
  @@index([testCaseId])
}

model TestRun {
  id          String          @id @default(cuid())
  projectId   String
  key         String
  name        String
  environment String?
  status      String          @default("PLANNED")
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions  TestExecution[]

  @@unique([projectId, key])
  @@index([projectId, status])
}

model TestExecution {
  id              String    @id @default(cuid())
  testRunId       String
  testCaseId      String
  status          String    @default("NOT_RUN")
  assigneeName    String?
  actualResult    String?
  notes           String?
  durationSeconds Int?
  executedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  testRun         TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCase        TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Restrict)
  defects         Defect[]

  @@unique([testRunId, testCaseId])
  @@index([testRunId, status])
  @@index([testCaseId])
}

model Defect {
  id          String         @id @default(cuid())
  projectId   String
  testCaseId  String?
  executionId String?
  key         String
  title       String
  description String?
  severity    String         @default("MEDIUM")
  priority    String         @default("MEDIUM")
  status      String         @default("OPEN")
  externalUrl String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCase    TestCase?      @relation(fields: [testCaseId], references: [id], onDelete: SetNull)
  execution   TestExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([testCaseId])
  @@index([executionId])
}

model Tag {
  id        String        @id @default(cuid())
  projectId String
  name      String
  color     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCaseTag[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TestCaseTag {
  testCaseId String
  tagId      String
  assignedAt DateTime @default(now())
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([testCaseId, tagId])
  @@index([tagId])
}

model User {
  id            String                   @id @default(cuid())
  name          String
  email         String                   @unique
  password      String
  role          String                   @default("QA")
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  notifications Notification[]
  notifPrefs    NotificationPreference?

  @@index([email])
  @@index([role])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // TEST_RUN_COMPLETE, DEFECT_ASSIGNED, STATUS_CHANGE, IMPORT_COMPLETE
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  emailEnabled    Boolean @default(true)
  testRunComplete Boolean @default(true)
  defectAssigned  Boolean @default(true)
  statusChange    Boolean @default(false)
  importComplete  Boolean @default(true)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
